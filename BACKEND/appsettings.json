{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER_NAME;Database=SmartLogAI;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "OutboundSettings": {
    "SecretKey": "YOUR_OUTBOUND_SECRET_KEY"
  },
  "JwtSettings": {
    "SecretKey": "YOUR_JWT_SECRET_KEY",
    "Issuer": "http://localhost:5184",
    "Audience": "http://localhost:3000",
    "ExpiryInMinutes": 1440
  },
  "GoogleAuth": {
    "ClientId": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
  },
  "AdminAccount": {
    "Username": "admin",
    "Password": "YOUR_ADMIN_PASSWORD",
    "FullName": "System Administrator",
    "Email": "admin@smartlogai.com",
    "Role": "ADMIN",
    "RoleID": 1
  },
  "AWS": {
    "AccessKeyId": "YOUR_AWS_ACCESS_KEY_ID",
    "SecretKey": "YOUR_AWS_SECRET_KEY",
    "Region": "ap-southeast-2",
    "S3": {
      "Bucket": "projectswp1"
    }
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUser": "smartlogai2026@gmail.com",
    "SmtpPass": "YOUR_SMTP_PASSWORD",
    "SenderName": "SmartLog AI - Warehouse Management",
    "SenderEmail": "smartlogai2026@gmail.com",
    "EnableSsl": true
  },
  "GeminiSettings": {
    "ApiKey": "YOUR_GEMINI_API_KEY",
    "Enabled": true,
    "UseFaqFallback": true,
    "TimeoutSeconds": 20
  },
  "PayOS": {
    "ClientId": "YOUR_PAYOS_CLIENT_ID",
    "ApiKey": "YOUR_PAYOS_API_KEY",
    "ChecksumKey": "YOUR_PAYOS_CHECKSUM_KEY",
    "FrontendBaseUrl": "http://localhost:3000"
  },
  "AzureVision": {
    "Endpoint": "https://hanora.cognitiveservices.azure.com/",
    "Key": "YOUR_AZURE_VISION_KEY"
  },
  "AzureComputerVision": {
    "Endpoint": "https://hanora.cognitiveservices.azure.com/",
    "ApiKey": "YOUR_AZURE_COMPUTER_VISION_KEY"
  },
  "GoongMaps": {
    "ApiKey": "YOUR_GOONG_MAPS_API_KEY",
    "MapTilesKey": "YOUR_GOONG_MAPS_TILES_KEY"
  },
  "LocationProvider": {
    "UseGoongMaps": true,
    "Limit": 8
  }
}